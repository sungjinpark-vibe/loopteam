# Unity generated — never track
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/
/[Rr]ecordings/

# Gate output
/Logs/gate-*.log
/Logs/gate-test-results.xml

# Visual Studio / Rider / VS Code
.vs/
.idea/
.vscode/
*.csproj
*.unityproj
*.sln
*.user
*.suo
*.userprefs
*.pidb
*.booproj
*.svd

# Builds / binaries
*.apk
*.aab
*.unitypackage
*.app
# *.app above targets macOS app bundles, but Windows git (core.ignorecase=true
# by default) also matches it against any path *component* ending in ".app" --
# including our own Assets/LifeTown.App/ asmdef folder. Explicitly un-ignore
# our source folder so it isn't silently dropped from tracking.
!/Assets/LifeTown.App/
!/Assets/LifeTown.App/**

# OS
.DS_Store
Thumbs.db
